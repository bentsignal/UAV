{
  "name": "uav",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.15.4"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules .turbo",
    "clean:all": "turbo run clean",
    "dev": "turbo run dev --parallel --continue",
    "dev:convex": "turbo run dev --parallel --continue -F @uav/convex",
    "dev:cli": "turbo run dev --parallel --continue -F @uav/cli",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "corepack pnpm lint:ws",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "create-package": "turbo gen init",
    "uav": "pnpm --filter @uav/cli uav"
  },
  "devDependencies": {
    "@turbo/gen": "^2.5.8",
    "@uav/prettier-config": "workspace:*",
    "dotenv-cli": "^10.0.0",
    "portless": "catalog:",
    "prettier": "catalog:",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "prettier": "@uav/prettier-config"
}
