{
  "name": "@uav/cli",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "uav": "./src/index.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "dev": "node --experimental-strip-types src/index.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "format:fix": "prettier --write . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit",
    "uav": "node --experimental-strip-types src/index.ts"
  },
  "dependencies": {
    "@convex-dev/better-auth": "catalog:",
    "@uav/config": "workspace:*",
    "@uav/convex": "workspace:*",
    "@uav/std": "workspace:*",
    "better-auth": "catalog:",
    "commander": "catalog:",
    "convex": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@uav/eslint-config": "workspace:*",
    "@uav/prettier-config": "workspace:*",
    "@uav/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@uav/prettier-config"
}
